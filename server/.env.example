# ---------------------------------------------------------------------------
# LocalSchema AI - server environment
#
# Copy this file to `server/.env` and fill in the values.
# Only the variables under "Required" are needed to boot the API.
# The rest gate optional features and are validated only when that feature is on.
# ---------------------------------------------------------------------------

# --- Required ---------------------------------------------------------------
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB connection string. Local example:
#   mongodb://127.0.0.1:27017/localschema
# Atlas example:
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/localschema?retryWrites=true&w=majority
MONGODB_URI=

# Secrets. Generate unique values, never reuse across environments:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=b60a6402922b9ccdebf9455a8a18bd12e10310e92d21a51d456046034339a33a8bf43a2c3b3eb048d4703470cad69aa934fabc546dbac840b10955f4fc1226f8
JWT_REFRESH_SECRET=5c485aad2ea3cd2e2cc352d2f8711b33489913f4979ac7e3e2006976a459f0d2df404b70f1e9cb229cdfa9539f50a1cdf65c262cbc482fee0416a00af2407cec
COOKIE_SECRET=87cb40a3a1b3d67e4ce1f8ab73f3b840c47fdf5e37935623ae0c4a6aca220cd5eb2b67a1e3a2f02fde1710bd06890a5459deb9bd58f38daafe481081cdf102e1

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- AI (schema generation) -------------------------------------------------
# NEVER put a real key in this file — it is a committed template. Put real keys
# only in server/.env (which is gitignored).
#
# Choose the provider used to turn documents into JSON-LD:
#   AI_PROVIDER=openai  -> uses OPENAI_API_KEY / OPENAI_MODEL
#   AI_PROVIDER=gemini  -> uses GEMINI_API_KEY / GEMINI_MODEL
# Leave the active provider's key blank to keep AI generation disabled
# (document parsing still works without it).
AI_PROVIDER=gemini

# OpenAI: keys start with "sk-". Create at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini: keys start with "AIza". Create at https://aistudio.google.com/apikey
# Model must be one currently available to your key (older ones get retired).
# List yours: GET https://generativelanguage.googleapis.com/v1beta/models
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Email ------------------------------------------------------------------
# When EMAIL_ENABLED=false the app logs verification/reset links to the console
# instead of sending mail, so local development needs no SMTP server.
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="LocalSchema AI <no-reply@localschema.ai>"

# --- Seed data (section 29) -------------------------------------------------
# Used only by `npm run seed`. Never commit real credentials.
ADMIN_EMAIL=gouravsuman2006@gmail.com
ADMIN_PASSWORD=1234
DEMO_USER_EMAIL=gouravsuman2006@gmail.com
DEMO_USER_PASSWORD=
DEMO_AGENCY_EMAIL=gouravsuman2006@gmail.com
DEMO_AGENCY_PASSWORD=

# --- Billing (Phase 7) ------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Object storage (optional) ----------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
